# ====== Chemcode Environment ======
# Copy to .env (frontend) or .env.local — Vite only reads env files starting
# with VITE_.

# === Mode switch ===
# true: pure frontend, no backend required (mock layer)
# false: connect to Gateway server (pnpm server:dev in another terminal)
VITE_USE_MOCK=true

# === Real-mode endpoints ===
# When VITE_USE_MOCK=false, the frontend uses these.
# Default values match the Vite dev server proxy + the local Gateway.
VITE_API_BASE=/api
VITE_WS_URL=/ws

# Optional override for production deployment (full URL):
# VITE_API_BASE=https://chemcode.example.com/api
# VITE_WS_URL=wss://chemcode.example.com/ws

# === Gateway server config (server/.env) ===
PORT=8787
HOST=0.0.0.0
AUTH_TOKEN_SECRET=chemcode-dev-secret
AUTH_TOKEN_TTL=86400
CHEMCODE_DATA_DIR=./data

# === CORS (comma-separated list of allowed origins) ===
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8787

# === Qdrant SSH tunnel ===
QDRANT_SSH_HOST=127.0.0.1
QDRANT_SSH_PORT=22
QDRANT_SSH_USER=root
QDRANT_SSH_PASSWORD=
QDRANT_API_KEY=

# === Embedding API ===
# SiliconFlow BAAI/bge-m3 用于向量化检索
# 未设置环境变量时，代码内置默认 key（sk-trlx...），设置此变量可覆盖
EMBEDDING_PROVIDER=siliconflow
# EMBEDDING_API_KEY=  ← 可选，覆盖内置 key
EMBEDDING_MODEL=BAAI/bge-m3
