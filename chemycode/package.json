    "marked": "12.0.2",
    "pdf-parse": "^2.4.5",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/dompurify": "3.0.5",
    "@types/express": "^4.17.21",
    "@types/multer": "1.4.12",
    "@types/node": "22.9.0",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "8.5.13",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.1",
    "jsdom": "^29.1.1",
    "multer": "1.4.5-lts.1",
    "tsx": "4.19.2",
