# ====== Chemycode Environment ======
# Copy to .env (frontend) or .env.local — Vite only reads env files starting
# with VITE_.

# === Mode switch ===
# true: pure frontend, no backend required (mock layer)
# false: connect to Gateway server (pnpm server:dev in another terminal)
VITE_USE_MOCK=true

# === Real-mode endpoints ===
# When VITE_USE_MOCK=false, the frontend uses these.
# Default values match the Vite dev server proxy + the local Gateway.
VITE_API_BASE=/api
VITE_WS_URL=/ws

# Optional override for production deployment (full URL):
# VITE_API_BASE=https://chemycode.example.com/api
# VITE_WS_URL=wss://chemycode.example.com/ws

# === Gateway server config (server/.env) ===
PORT=8787
HOST=0.0.0.0
AUTH_TOKEN_SECRET=chemycode-dev-secret
AUTH_TOKEN_TTL=86400
CHEMYCODE_DATA_DIR=./data
